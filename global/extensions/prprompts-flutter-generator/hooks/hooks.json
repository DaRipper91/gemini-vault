{
  "hooks": {
    "AfterTool": [
      {
        "matcher": "replace|write_file",
        "hooks": [
          {
            "type": "command",
            "command": "dart format --set-exit-if-changed ${workspacePath}/lib || true",
            "timeout": 30000,
            "description": "Auto-format Dart files after changes"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"additionalContext\": \"Ready for next steps. Consider running tests or linting if you have made major changes.\"}}'",
            "timeout": 5000,
            "description": "Completion reminder"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${extensionPath}/scripts/check-flutter-sdk.sh || true",
            "timeout": 10000,
            "description": "Verify Flutter SDK"
          }
        ]
      }
    ]
  }
}